NODE_ENV=production
PORT=10000
ENABLE_SWAGGER=false
CORS_ORIGIN=https://dashboard.observantsecurity.co.uk,https://your-mobile-web-host.example.com
TRUST_PROXY=true
DATABASE_POOLER_URL=
