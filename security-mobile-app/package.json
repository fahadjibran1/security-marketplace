{
  "name": "security-mobile-app",
  "version": "0.2.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "install:mobile": "npm install",
    "start": "node backend/server.js",
    "start:backend": "node backend/server.js",
    "start:mobile": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios:simulator": "eas build --platform ios --profile ios-simulator",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "node --check backend/server.js && node --check backend/modules/auth.js && node --check backend/modules/http.js && node --check backend/data/store.js",
    "build:frontend": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@types/react": "~18.2.79",
    "expo": "~51.0.28",
    "expo-secure-store": "~13.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "typescript": "~5.3.3"
  }
}
