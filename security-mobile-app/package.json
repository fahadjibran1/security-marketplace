{
  "name": "security-mobile-app",
  "version": "0.2.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "install:mobile": "npm install",
    "start": "node backend/server.js",
    "start:backend": "node backend/server.js",
    "start:mobile": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios:simulator": "eas build --platform ios --profile ios-simulator",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "node --check backend/server.js && node --check backend/modules/auth.js && node --check backend/modules/http.js && node --check backend/data/store.js",
    "build:frontend": "tsc --noEmit",
    "build:brand-assets": "node scripts/build-s4-assets.cjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@types/react": "~19.1.10",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "jimp": "^0.22.12",
    "typescript": "~5.9.2"
  }
}
