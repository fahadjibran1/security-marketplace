{
  "expo": {
    "name": "Security Marketplace",
    "slug": "security-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.securitymarketplace.mobile"
    },
    "android": {
      "package": "com.securitymarketplace.mobile"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:3000",
      "eas": {
        "projectId": "c786f15c-7d60-4122-9001-02cabbb7692b"
      }
    }
  }
}
