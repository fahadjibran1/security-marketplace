{
  "expo": {
    "name": "Security Marketplace",
    "slug": "security-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.securitymarketplace.mobile"
    },
    "android": {
      "package": "com.securitymarketplace.mobile"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:3000"
    }
  }
}
