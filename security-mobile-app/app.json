{
  "expo": {
    "name": "S4 Security",
    "description": "Staff. Sites. Shifts. Security.",
    "slug": "security-marketplace",
    "version": "1.0.0",
    "scheme": "securitymarketplace",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "primaryColor": "#0B1B2B",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F5F9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.securitymarketplace.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.securitymarketplace.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1B2B"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "https://security-marketplace-api.onrender.com",
      "eas": {
        "projectId": "c786f15c-7d60-4122-9001-02cabbb7692b"
      }
    }
  }
}
