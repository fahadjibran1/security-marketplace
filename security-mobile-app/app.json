{
  "expo": {
    "name": "Security Marketplace",
    "slug": "security-marketplace",
    "version": "1.0.0",
    "scheme": "securitymarketplace",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.securitymarketplace.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.securitymarketplace.mobile"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "https://security-marketplace-api.onrender.com",
      "eas": {
        "projectId": "c786f15c-7d60-4122-9001-02cabbb7692b"
      }
    }
  }
}
