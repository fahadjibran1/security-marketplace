+  @OneToMany(() => Job, (job) => job.company)
+  jobs?: Job[];
+
+  @OneToMany(() => Assignment, (assignment) => assignment.company)
+  assignments?: Assignment[];
+
+  @OneToMany(() => Shift, (shift) => shift.company)
