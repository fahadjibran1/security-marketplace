+import { Timesheet } from '../../timesheet/entities/timesheet.entity';
+
+@Entity('companies')
+export class Company {
+  @PrimaryGeneratedColumn()
+  id!: number;
+
+  @OneToOne(() => User, { eager: true })
+  @JoinColumn({ name: 'userId' })
+  user!: User;
+
+  @Column()
+  name!: string;
+
+  @Column()
+  companyNumber!: string;
+
+  @Column()
+  address!: string;
+
+  @Column()
+  contactDetails!: string;
